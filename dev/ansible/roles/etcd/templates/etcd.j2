{% if inventory_hostname == 'mwdb_servers_master' %}
ETCD_NAME="node1"
{% else %}
ETCD_NAME="node2"
{% endif %}

ETCD_DATA_DIR="/var/lib/etcd/pg-database"
ETCD_LISTEN_PEER_URLS="http://0.0.0.0:2380"
ETCD_LISTEN_CLIENT_URLS="http://0.0.0.0:2379"
ETCD_INITIAL_ADVERTISE_PEER_URLS="http://{{ ansible_default_ipv4.address }}:2380"
ETCD_INITIAL_CLUSTER="node1=http://{{ hostvars['mw-db-master']['ansible_host'] }}:2380, node2=http://{{ hostvars['mw-db-replica']['ansible_host'] }}:2380"
ETCD_INITIAL_CLUSTER_STATE="new"
ETCD_INITIAL_CLUSTER_TOKEN="pg-cluster"
ETCD_ADVERTISE_CLIENT_URLS="http://{{ ansible_default_ipv4.address }}:2379"